# iob-integration — AI Intelligence Platform Gateway
# Environment configuration template — Phase 1 Embedding Lock
# Copy to iob-integration/.env
#
# This file is consumed by Member 1's Platform Backend gateway.
# Keep EMBEDDING_MODEL_NAME / VECTOR_DIMENSION in sync with
# brain_intelligence-main/.env.example

# ==============================================================================
# AI/ML & VECTOR ENGINE CONFIGURATION
# ==============================================================================
# Model selection alters the required vector collection dimensions in Qdrant.
# Defaulting to 768d for higher retrieval performance over plan baseline.
EMBEDDING_MODEL_NAME=all-mpnet-base-v2
VECTOR_DIMENSION=768

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_OPERATIONAL=operational_knowledge_v4
QDRANT_VECTOR_SIZE=768
QDRANT_DISTANCE_METRIC=Cosine

# --- Embedding runtime ---
EMBEDDING_MODEL_NAME=sentence-transformers/all-mpnet-base-v2
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_SEQ_LENGTH=512

# --- Platform Gateway (Member 1) ---
PLATFORM_GATEWAY_BASE_URL=http://localhost:8080
PLATFORM_GATEWAY_SERVICE_TOKEN=changeme_service_token

# --- Telemetry Ingest (Member 2) ---
TELEMETRY_INGEST_QUEUE_URL=kafka://localhost:9092/telemetry.raw
TELEMETRY_SCHEMA_VERSION=1.0.0
TELEMETRY_MAX_BATCH_SIZE=500

# --- Auth ---
JWT_SECRET_KEY=changeme_super_secret_key
SERVICE_API_KEY=changeme_internal_service_key

# See brain_intelligence-main/.env.example for the full AI platform config.
