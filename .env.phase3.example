# =============================================================================
# PHASE 3 — BACKEND-ONLY SMOKE TEST · ENVIRONMENT ADDITIONS
# Member 3 (Lathika — AI/ML Knowledge Engineer)
# -----------------------------------------------------------------------------
# This file holds ONLY the Phase 3 networking/integration tunables. It is meant
# to be MERGED into your existing `.env` (which already carries the full Phase 1
# embedding-lock config from `.env.example`). Do not replace `.env` wholesale.
#
# Usage:
#   # 1. Start from the full config:
#   cp .env.example .env
#   # 2. Append these Phase 3 additions (or pass both files to compose):
#   docker compose -f docker-compose.phase3.yml --env-file .env --env-file .env.phase3 up --build -d
#
# NOTHING here overrides the Phase 1 embedding lock. EMBEDDING_MODEL_NAME /
# QDRANT_VECTOR_SIZE remain all-mpnet-base-v2 / 768.
# =============================================================================

# --- Phase 3 runtime mode --------------------------------------------------
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- Cross-container networking (set by compose; documented here for clarity) ---
# The gateway resolves the AI service by its Compose service DNS name on the
# shared iob-net bridge network. `localhost` would point INSIDE each container
# and must NEVER be used for inter-service traffic.
AI_SERVICE_URL=http://brain_intelligence:8000
AI_PLATFORM_URL=http://brain_intelligence:8000
NEO4J_URI=bolt://neo4j:7687
QDRANT_URL=http://qdrant:6333
PLATFORM_GATEWAY_BASE_URL=http://gateway:8000

# --- Internal-only guard token (shared between gateway + AI service) -------
# The gateway forwards this as X-Internal-Service-Token so the AI service's
# InternalOnlyGuardMiddleware treats the relay as a trusted internal call.
# In APP_ENV=development the guard also has a logged bypass for smoke testing.
SERVICE_API_KEY=changeme_internal_service_key

# --- Deterministic, key-free synthesis for the smoke test ------------------
LLM_PROVIDER=mock
PDM_INFERENCE_FALLBACK_MODE=heuristic

# --- Neo4j hard-dependency truth flag --------------------------------------
# Set PHASE3_NEO4J_REQUIRED=true when you intend to exercise GraphRAG live.
# The audit scripts use this to decide whether a missing graph is a SKIP or FAIL.
PHASE3_NEO4J_REQUIRED=false

# --- Transparent relay gate (Phase 3 byte-identical enforcement) -----------
PHASE3_TRANSPARENT_RELAY=true

# --- Gateway DB (Member 1) -------------------------------------------------
DATABASE_URL=postgresql://iob_user:iob_password_2026@postgres:5432/iob_platform
JWT_SECRET_KEY=changeme_super_secret_key
