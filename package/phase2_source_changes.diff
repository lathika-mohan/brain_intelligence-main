+    def test_feature_payload_gracefully_falls_back_when_service_import_unavailable(
+        self, client: TestClient, monkeypatch
+    ):
+        real_import = builtins.__import__
+
+        def guarded_import(name, globals=None, locals=None, fromlist=(), level=0):
+            if name == "app.predictive.prediction_service":
+                raise ModuleNotFoundError("simulated missing predictive runtime")
+            return real_import(name, globals, locals, fromlist, level)
+
+        monkeypatch.setattr(builtins, "__import__", guarded_import)
+
+        res = client.post(
+            "/api/v1/predictive/infer",
+            json={
+                "asset_id": "asset-101",
+                "component_id": "asset-101-bearing-de",
+                "features": {
+                    "vibration": 4.2,
+                    "temperature": 92.5,
+                    "pressure": 8.2,
+                    "rpm": 2950.0,
+                },
+                "horizon_hours": 24,
+            },
+        )
+
+        assert res.status_code == 200
+        envelope = res.json()
+        assert envelope["success"] is True
+        assert envelope["error"] is None
+        data = envelope["data"]
+        assert data["asset_id"] == "asset-101"
+        assert data["fallback_used"] is True
+        assert "rul" in data
+        assert "failure_probability" in data
+        assert "anomaly_flags" in data
+        assert "generated_at" in data
+        assert "inference_latency_ms" in data
+
     def test_health_endpoint_reports_ready(self, client: TestClient):
         res = client.get("/api/v1/predictive/health")
         assert res.status_code == 200
