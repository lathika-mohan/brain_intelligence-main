# =============================================================================
# Industrial Operating Brain (IOB) — AI Intelligence Platform
# Environment configuration template (Phase 0)
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# =============================================================================

# --- Runtime ---------------------------------------------------------------
APP_ENV=development                 # development | staging | production
APP_NAME="IOB AI Intelligence Platform"
APP_VERSION=0.1.0
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
DEBUG=true

# --- CORS (must include the Next.js frontend origin) ------------------------
CORS_ALLOW_ORIGINS=http://localhost:3000,https://app.iob.enterprise.internal

# --- FastAPI server ----------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Neo4j (Graph Database) --------------------------------------------------
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme_neo4j_password
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_LIFETIME=3600
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30

# --- Qdrant (Vector Database) ------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_GRPC_PORT=6334
QDRANT_PREFER_GRPC=false
QDRANT_COLLECTION_SOP_DOCS=sop_documents
QDRANT_COLLECTION_MANUALS=technical_manuals
QDRANT_COLLECTION_INCIDENTS=incident_reports
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE_METRIC=Cosine

# --- Embedding model ----------------------------------------------------------
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DEVICE=cpu                 # cpu | cuda
EMBEDDING_BATCH_SIZE=32
EMBEDDING_MAX_SEQ_LENGTH=256

# --- GraphRAG fusion tuning ---------------------------------------------------
GRAPHRAG_TOP_K_VECTOR=8
GRAPHRAG_MAX_GRAPH_HOPS=3
GRAPHRAG_MIN_CONFIDENCE_THRESHOLD=0.55
GRAPHRAG_MAX_CONTEXT_CHUNKS=12

# --- Predictive Maintenance model registry ------------------------------------
PDM_MODEL_REGISTRY_PATH=./artifacts/models
PDM_RUL_MODEL_NAME=xgboost_rul_v1
PDM_FAILURE_MODEL_NAME=xgboost_failure_classifier_v1
PDM_ANOMALY_MODEL_NAME=isolation_forest_v1
PDM_ANOMALY_CONTAMINATION=0.02
PDM_INFERENCE_FALLBACK_MODE=heuristic   # heuristic | last_known_good | reject

# --- Explainability (XAI) ------------------------------------------------------
XAI_SHAP_BACKGROUND_SAMPLES=100
XAI_LIME_NUM_FEATURES=10
XAI_LIME_NUM_SAMPLES=500
XAI_MIN_CONFIDENCE_THRESHOLD=0.5

# --- Decision Engine ------------------------------------------------------------
DECISION_ENGINE_MAX_RECOMMENDATIONS=5
DECISION_ENGINE_RISK_HORIZON_DAYS=30

# --- Upstream telemetry ingestion (Member 2 — PLC/SCADA) ------------------------
TELEMETRY_INGEST_QUEUE_URL=kafka://localhost:9092/telemetry.raw
TELEMETRY_SCHEMA_VERSION=1.0.0
TELEMETRY_MAX_BATCH_SIZE=500

# --- Downstream enterprise gateway (Member 1 — Platform Backend) ---------------
PLATFORM_GATEWAY_BASE_URL=http://localhost:8080
PLATFORM_GATEWAY_SERVICE_TOKEN=changeme_service_token

# --- Auth / security -------------------------------------------------------------
JWT_SECRET_KEY=changeme_super_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
SERVICE_API_KEY=changeme_internal_service_key
