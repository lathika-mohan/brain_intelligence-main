# API Execution Configuration
NEXT_PUBLIC_API_URL=https://api.iob.enterprise.internal/v1
NEXT_PUBLIC_WS_URL=wss://stream.iob.enterprise.internal/v1

# Section 7 — Decoupled Network Layer
# The request interceptor (src/api/interceptors.ts) reads the bearer token
# from localStorage under this key (see src/utils/constants.ts::AUTH_TOKEN_KEY).
# No env var needed for this — documented here for reference only:
#   localStorage key: iob_auth_token

# Node Environment
NODE_ENV=development

# Feature Toggle Configuration
NEXT_PUBLIC_ENABLE_SHAP_EXPLAINABILITY=true
NEXT_PUBLIC_ENABLE_GRAPH_RAG=true
NEXT_PUBLIC_ENABLE_DIGITAL_TWIN_STREAMING=true

# Security Configuration
NEXT_PUBLIC_CSP_REPORT_ONLY=false
